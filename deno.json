{
	"nodeModulesDir": "none",
	"tasks": {
		"fmt": "deno fmt",
		"fmt:check": "deno fmt --check",
		"lint": "deno lint",
		"test": "deno test --allow-read --allow-write --allow-env --allow-run",
		"agent": "deno run --unstable-raw-imports --allow-all agent/index.ts",
		"playground:agent": "deno run --allow-all tui/playground/agent.tsx",
		"playground:command-palette": "deno run --allow-all tui/playground/command-palette.tsx",
		"playground:layout": "deno run --allow-all tui/playground/layout.tsx",
		"playground:markdown": "deno run --allow-all tui/playground/markdown.tsx",
		"playground:scroll-area": "deno run --allow-all tui/playground/scroll-area.tsx",
		"playground:spinner": "deno run --allow-all tui/playground/spinner.tsx",
		"playground:text-input": "deno run --allow-all tui/playground/text-input.tsx",
		"playground:text-styling": "deno run --allow-all tui/playground/text-styling.tsx",
		"playground:welcome": "deno run --allow-all tui/playground/welcome.tsx",
		"build": "deno run --allow-all scripts/build.ts",
		"version": "deno eval \"import {VERSION} from './version.ts'; console.log(VERSION)\"",
		"version:bump": "deno run --allow-write=version.ts,README.md --allow-read=README.md scripts/bump.ts"
	},
	"imports": {
		"@preact/signals-core": "npm:@preact/signals-core@^1.11.1",
		"yoga-layout": "npm:yoga-layout@^3.2.1",
		"@/": "./",
		"@/api/": "./api/",
		"@/core/": "./core/",
		"@/agent/": "./agent/",
		"@/tui/": "./tui/",
		"@/tui/render/jsx-runtime": "./tui/render/jsx-runtime.ts",
		"@/tui/render/jsx-dev-runtime": "./tui/render/jsx-dev-runtime.ts",
		"@std/assert": "jsr:@std/assert@^1",
		"@std/dotenv": "jsr:@std/dotenv@^0.225",
		"@std/path": "jsr:@std/path@^1"
	},
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "@/tui/render"
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 120,
		"indentWidth": 4,
		"semiColons": true,
		"singleQuote": false
	},
	"lint": {
		"rules": {
			"exclude": ["no-explicit-any"]
		}
	}
}
